{
  "agents": {
    "defaults": {
      "compaction": {
        "mode": "safeguard",
        "maxHistoryShare": 0.85,
        "reserveTokens": 3000,
        "keepRecentTokens": 2000,
        "recentTurnsPreserve": 5,
        "reserveTokensFloor": 500,
        "postCompactionSections": [
          "Session Startup",
          "Safety",
          "Every Session",
          "Red Lines"
        ],
        "memoryFlush": {
          "enabled": true,
          "interval": "5m"
        }
      }
    }
  },
  "acp": {
    "session": {
      "idleTtlMs": 604800000,
      "maxSessions": 10000,
      "persistence": {
        "enabled": true,
        "path": "/root/.openclaw/workspace/guardian-ai/sessions",
        "autoSaveInterval": 60000
      }
    }
  }
}