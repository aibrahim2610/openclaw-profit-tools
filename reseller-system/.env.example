# OpenRouter Reseller System - Environment Configuration
# =====================================================

# Required: Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YourOpenRouterKeyHere

# Server
PORT=3001
NODE_ENV=production
SITE_URL=http://localhost:3001

# Admin Security (change this!)
SERVER_SECRET=change-me-to-strong-random-string

# Future: Stripe Integration (when you get Stripe account)
# STRIPE_SECRET_KEY=sk_live_your_stripe_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Future: Orange Money/Fawry for payouts
# ORANGE_MONEY_API_KEY=your_orange_money_api_key
# ORANGE_MONEY_MERCHANT_ID=your_merchant_id
# PAYOUT_METHOD=orange_money
# ORANGE_MONEY_PHONE=+201202902013

# Database (currently in-memory, for production use Redis/Postgres)
# DATABASE_URL=redis://localhost:6379/0

# Monitoring
ENABLE_METRICS=true